{
  "expo": {
    "scheme": "routertv",
    "backgroundColor": "#000000",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icons/icon-1024.png",
    "version": "0.0.2",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#180B6F",
          "image": "./assets/icons/icon-1024.png",
          "dark": {
            "image": "./assets/icons/icon-1024.png",
            "backgroundColor": "#180B6F"
          },
          "imageWidth": 200
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/tv_icons/icon-400x240.png",
          "appleTVImages": {
            "icon": "./assets/tv_icons/icon-1280x768.png",
            "iconSmall": "./assets/tv_icons/icon-400x240.png",
            "iconSmall2x": "./assets/tv_icons/icon-800x480.png",
            "topShelf": "./assets/tv_icons/icon-1920x720.png",
            "topShelf2x": "./assets/tv_icons/icon-3840x1440.png",
            "topShelfWide": "./assets/tv_icons/icon-2320x720.png",
            "topShelfWide2x": "./assets/tv_icons/icon-4640x1440.png"
          }
        }
      ],
      ["./plugins/with-runtime-framework-headers.js"],
      [
        "./plugins/withGitPod.js",
        {
          "podName": "MPVKit-GPL",
          "podspecUrl": "https://raw.githubusercontent.com/streamyfin/MPVKit/0.40.0-av/MPVKit-GPL.podspec"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "15.6",
            "useFrameworks": "static"
          }
        }
      ],
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "react-native-video",
      "expo-image"
    ],
    "android": {
      "package": "com.anonymous.houndapp",
      "permissions": []
    },
    "ios": {
      "splash": {
        "image": "./assets/images/splash.png"
      },
      "bundleIdentifier": "com.anonymous.houndapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "output": "static"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "name": "Hound Beta",
    "slug": "hound-app",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1906e8aa-5f95-48be-b39b-07340f2e9e78"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1906e8aa-5f95-48be-b39b-07340f2e9e78",
      "checkAutomatically": "ON_ERROR_RECOVERY"
    }
  }
}
