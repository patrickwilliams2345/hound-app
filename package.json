{
  "name": "hound-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "EXPO_TV=1 expo start",
    "android": "EXPO_TV=1 expo run:android",
    "ios": "EXPO_TV=1 expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "reset-project": "./scripts/reset-project.js",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy"
  },
  "dependencies": {
    "@cospired/i18n-iso-languages": "^4.2.0",
    "@expo-google-fonts/cabin": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/slider": "5.1.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.12",
    "expo": "^55.0.5",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-navigation-bar": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-screen-orientation": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.12",
    "expo-web-browser": "~55.0.9",
    "nativewind": "^4.2.1",
    "patch-package": "^8.0.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "npm:react-native-tvos@0.83.2-0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-video": "6.19.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.19",
    "toastify-react-native": "^7.2.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "private": true
}
